# ── Grok / xAI (primary AI for trip plans + price refinement) ──────────
# Get a key at https://console.x.ai/
VITE_GROK_API_KEY=
VITE_GROK_MODEL=grok-4.20-reasoning

# ── Amadeus Self-Service API (real flight data via GDS) ────────────────
# Sign up FREE at https://developers.amadeus.com/  →  Create app  →  copy keys.
# Free tier: 2000 flight searches/month, real prices from Skyscanner-grade data.
# These are SERVER-side keys — NO VITE_ prefix.  Set them in Vercel project
# settings → Environment Variables (or in this .env for local Vercel dev).
AMADEUS_CLIENT_ID=
AMADEUS_CLIENT_SECRET=
# Set to "production" only after upgrading to a paid Amadeus production app.
AMADEUS_ENV=test

# ── Google Gemini (optional legacy fallback, deprecated) ───────────────
# Not used by default; kept for backwards compatibility.
VITE_GEMINI_API_KEY=
